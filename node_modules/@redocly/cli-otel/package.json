{
  "name": "@redocly/cli-otel",
  "version": "0.1.2",
  "type": "module",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "author": "team@redocly.com",
  "license": "MIT",
  "description": "Redocly CLI OpenTelemetry",
  "dependencies": {
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@redocly/cli": "2.24.0",
    "typescript": "5.9.3",
    "esbuild": "0.27.0",
    "@redocly/asyncapi-sdk-generator": "0.1.0"
  },
  "nx": {
    "namedInputs": {
      "prod": [
        "{workspaceRoot}/docs/intranet/apis/cli-otel/**/*",
        "{projectRoot}/package.json",
        "!{projectRoot}/**/.cache"
      ]
    }
  },
  "scripts": {
    "build": "pnpm run clean && pnpm run lint && pnpm run bundle && pnpm run generate && tsc --emitDeclarationOnly && pnpm run build:js && pnpm run generate:hash",
    "build:js": "esbuild src/index.ts --bundle --minify --sourcemap --format=esm --platform=node --external:ulid --outfile=lib/index.js",
    "clean": "rm -rf .cache && rm -rf src/generated-async-redoc && rm -rf lib/",
    "bundle": "redocly bundle ../../docs/intranet/apis/cli-otel/asyncapi.yaml --output .cache/cli-otel.yaml",
    "generate": "asyncapi-sdk-generator --input .cache/cli-otel.yaml --output src/generated-async-redocly-cli --configPath asyncapi-sdk-config.json --generate-types-only-client --generate-standalone-mappers --provider node",
    "generate:hash": "asyncapi-sdk-generator --input ./.cache --output . --generate-document-hash",
    "lint": "redocly lint --config=../../docs/intranet/asyncapi-styleguide-base.yaml --format=stylish ../../docs/intranet/apis/cli-otel/asyncapi.yaml"
  }
}